# Copie ce fichier en ".env" (sans ".example") et remplis tes propres valeurs.
# Le fichier ".env" est ignoré par Git (voir .gitignore) : il ne sera jamais poussé sur GitHub.

DJANGO_SECRET_KEY=une-cle-random-juste-pour-le-local-pas-besoin-detre-forte
DJANGO_DEBUG=True

# Compte admin recréé automatiquement à chaque "python manage.py seed_exercises"
# (uniquement utilisé en local, grâce à createsuperuser --noinput)
DJANGO_SUPERUSER_EMAIL=admin@codexo.local
DJANGO_SUPERUSER_PASSWORD=admin123
